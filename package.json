{
  "name": "mobile",
  "version": "2026.06.25",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --localhost",
    "start": "expo start --localhost",
    "tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "version:update": "node scripts/update-version.js",
    "build:dev": "APP_ENV=development npx eas-cli build --platform all --profile development",
    "build:dev:android": "APP_ENV=development npx eas-cli build --platform android --profile development",
    "build:dev:ios": "APP_ENV=development npx eas-cli build --platform ios --profile development",
    "build:preview": "APP_ENV=preview npx eas-cli build --platform all --profile preview",
    "build:preview:android": "APP_ENV=preview npx eas-cli build --platform android --profile preview",
    "build:preview:ios": "APP_ENV=preview npx eas-cli build --platform ios --profile preview",
    "build:prod": "APP_ENV=production npx eas-cli build --platform all --profile production",
    "build:prod:android": "APP_ENV=production npx eas-cli build --platform android --profile production",
    "build:prod:ios": "APP_ENV=production npx eas-cli build --platform ios --profile production",
    "update:preview": "APP_ENV=preview node scripts/update-with-summary.js --branch preview",
    "update:production": "APP_ENV=production node scripts/update-with-summary.js --branch production"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/spectral": "^0.4.1",
    "@expo/metro-runtime": "~56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@tanstack/react-query": "^5.101.1",
    "babel-preset-expo": "~56.0.15",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "^56.0.7",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-insights": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-observe": "~56.0.21",
    "expo-router": "~56.2.11",
    "expo-screen-capture": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "^56.0.19",
    "expo-video": "~56.1.4",
    "metro-runtime": "^0.84.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "^4.3.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.17",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "typescript": "~6.0.3"
  },
  "private": true
}
