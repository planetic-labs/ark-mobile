{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "http://localhost:8000/api/v1"
      }
    },
    "preview": {
      "developmentClient": false,
      "channel": "preview",
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://dev-api.yourdomain.com/api/v1"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.yourdomain.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
